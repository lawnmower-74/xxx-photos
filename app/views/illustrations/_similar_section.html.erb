<%# --- 類似画像一覧 --- %>
<% if @similar_illustrations.present? %>
  <div style="margin-bottom: 40px; padding: 20px; background: #fff9f0; border: 2px dashed #ffc107; border-radius: 12px;">
    <h2 style="margin-top: 0; color: #856404; font-size: 1.1em; display: flex; align-items: center; gap: 8px;">
      ⚠️ もしかしたら同じ画像かも？
    </h2>
    <p style="font-size: 0.85em; color: #7d6a3a; margin-bottom: 15px;">
      特徴が非常に近い画像が見つかりました。不要なものを削除して整理できます。
    </p>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 15px;">
      <% @similar_illustrations.each do |illustration| %>
        <div class="illustration-item" id="similar-item-<%= illustration.id %>" style="position: relative; border: 1px solid #ffeeba; border-radius: 8px; overflow: hidden; background: white;">

          <%# 一括削除用チェックボックス %>
          <input type="checkbox" class="delete-checkbox" data-id="<%= illustration.id %>" 
                  style="position: absolute; top: 8px; left: 8px; z-index: 10; width: 18px; height: 18px; cursor: pointer;">
          
          <%# 画像表示 %>
          <% if illustration.image.attached? %>
            <%# 拡大リンク（クリック時に原寸大の画像を表示） %>
            <a href="<%= url_for(illustration.image) %>" 
              class="spotlight" 
              data-group="similar-gallery"
              style="display: block;">
              <%# サムネイル %>
              <%= image_tag illustration.image.variant(resize_to_limit: [200, 200]),
                            loading: "lazy", 
                            style: "width: 100%; height: 140px; object-fit: cover; display: block;" %>
            </a>
          <% end %>

          <div style="padding: 6px; text-align: center;">
            <%# 撮影日時 %>
            <span style="font-size: 0.75em; color: #666;">
              📅 <%= illustration.shot_at&.strftime("%m/%d %H:%M") %>
            </span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>